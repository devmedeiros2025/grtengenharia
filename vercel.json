{
  "version": 2,
  "public": true,
  "buildCommand": null,
  "outputDirectory": "public",
  "routes": [
    { "src": "/api/(.*)", "dest": "https://crm-grt-api.onrender.com/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
