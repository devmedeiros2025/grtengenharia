# ── Servidor ──
PORT=3002                              # Porta onde o servidor HTTP irá rodar
NODE_ENV=development                   # development | production

# ── JWT (OBRIGATÓRIO) ──
JWT_SECRET=uma-chave-secreta-forte-aqui # Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_EXPIRES_IN=7d                       # Tempo de expiração do token (ex: 15m, 1h, 7d)

# ── Banco SQLite (desenvolvimento local) ──
DB_PATH=./data/crm.db                   # Caminho do arquivo SQLite (usado quando Supabase não configurado)

# ── CORS ──
CORS_ORIGIN=http://localhost:3001       # Origens permitidas para CORS (separar por vírgula: url1,url2,url3)

# ── Supabase (produção - obrigatório em produção) ──
SUPABASE_URL=https://seu-projeto.supabase.co            # URL do projeto Supabase (Dashboard > Settings > API)
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role        # Service Role Key (Dashboard > Settings > API > service_role)

# ── n8n (opcional - integração com n8n) ──
N8N_WEBHOOK_URL=                        # URL do webhook n8n para disparos
N8N_API_KEY=                            # API Key do n8n

# ── Logging (opcional) ──
LOG_LEVEL=info                          # error | warn | info | debug
